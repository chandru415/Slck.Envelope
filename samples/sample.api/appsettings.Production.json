{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "SlckEnvelope": {
    "Observability": {
      "Enabled": true,
      "ActivitySourceName": "TicketAPI",
      "ActivitySourceVersion": "1.0.0",
      "EnableSerilogEnrichment": true,
      "EnableAutoTracing": true,
      "DefaultTags": {
        "Environment": "Production",
        "Application": "TicketAPI",
        "Team": "Platform",
        "CostCenter": "Engineering"
      },
      "OpenTelemetry": {
        "Enabled": true,
        "ServiceName": "TicketAPI",
        "ServiceVersion": "1.0.0",
        "Environment": "Production",
        "Region": "us-east-1",
        "OtlpEndpoint": "http://alloy:4317",
        "Protocol": "Grpc",
        "EnableConsoleExporter": false,
        "EnableAspNetCoreInstrumentation": true,
        "EnableHttpClientInstrumentation": true,
        "EnableSqlClientInstrumentation": true,
        "EnableRuntimeMetrics": true,
        "EnableProcessMetrics": true,
        "ResourceAttributes": {
          "host.name": "prod-server-01",
          "deployment.id": "v1.0.0-20240131",
          "k8s.namespace": "production",
          "k8s.pod.name": "ticketapi-7d9f8c4b5-xyz12"
        },
        "AdditionalSources": [
          "MediatR",
          "NATS.Client",
          "Redis",
          "EntityFrameworkCore"
        ],
        "AdditionalMeters": [
          "MediatR.*",
          "NATS.*",
          "Redis",
          "Microsoft.EntityFrameworkCore"
        ],
        "ExcludePaths": [
          "/health",
          "/metrics",
          "/swagger",
          "/favicon.ico"
        ]
      },
      "Serilog": {
        "Enabled": true,
        "EnableRequestLogging": true,
        "EnrichWithThreadId": true,
        "EnrichWithProcessId": true,
        "EnrichWithEnvironment": true,
        "MinimumLevel": "Information",
        "MinimumLevelOverrides": {
          "Microsoft": "Warning",
          "System": "Error",
          "Microsoft.AspNetCore": "Warning",
          "Microsoft.EntityFrameworkCore": "Warning"
        },
        "WriteToConsole": false,
        "WriteToFile": true,
        "FilePath": "logs/ticketapi-.log",
        "WriteToOpenTelemetry": true,
        "OpenTelemetryEndpoint": "http://alloy:4317",
        "OpenTelemetryProtocol": "Grpc"
      }
    }
  }
}
